# BrightData API (recommended -- ~$0.001/record)
# Sign up at https://brightdata.com (free trial)
# Get API key from Account Settings -> API Keys
BRIGHTDATA_API_KEY=

# ScrapIn API (alternative -- ~$0.01/record)
# Sign up at https://www.scrapin.io/pricing ($30 trial)
SCRAPIN_API_KEY=

# Turso Database
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Data provider: "brightdata" | "scrapin" | "mock"
# Default: "mock" (uses deterministic fake data for development)
DATA_PROVIDER=mock
